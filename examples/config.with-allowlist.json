{
  "allowlist": {
    "enabled": true,
    "domains": ["your-org.com"],
    "emails": ["specific.outsider@gmail.com"]
  },
  "audit_log": {
    "enabled": true,
    "include_reads": true,
    "path": null,
    "max_size_bytes": 10485760,
    "max_backups": 5,
    "verify_on_startup": true
  },
  "attachments": {
    "max_total_bytes": 20971520,
    "allowed_paths": [
      "~/Documents",
      "~/Downloads"
    ],
    "deny_patterns": [],
    "use_default_deny_patterns": true
  },
  "rate_limit": {
    "enabled": true,
    "sends_per_hour": 30
  }
}
